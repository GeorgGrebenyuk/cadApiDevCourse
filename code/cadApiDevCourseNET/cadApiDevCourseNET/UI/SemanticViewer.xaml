<UserControl x:Class="cadApiDevCourseNET.UI.SemanticViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:cadApiDevCourseNET.UI"
             mc:Ignorable="d" 
             >
    <Grid>
        <ListView x:Name="ListView_Info" ScrollViewer.VerticalScrollBarVisibility="Visible">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=Caption}" Width="150" Header="Имя свойства"></GridViewColumn>
                    <GridViewColumn DisplayMemberBinding="{Binding Path=Value}" Width="Auto" Header="Значение свойства"></GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>    
    </Grid>
</UserControl>
